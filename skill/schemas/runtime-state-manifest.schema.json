{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/socratic/runtime-state-manifest.schema.json",
  "title": "RuntimeStateManifest",
  "type": "object",
  "required": [
    "skill_name",
    "skill_version",
    "state_schema_version",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "skill_name": {
      "type": "string",
      "const": "socratic"
    },
    "skill_version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "state_schema_version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "runtime": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "storage_backend": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
